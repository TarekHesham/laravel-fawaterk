{
  "name": "elfarmawy/laravel-api-wrapper-template",
  "description": "Laravel package for template API integration",
  "type": "project",
  "license": "MIT",
  "version": "1.0.0",
  "keywords": [
    "elfarmawy",
    "laravel",
    "template",
    "template-API",
    "laravel-api-wrapper-template",
    "api-wrapper-template"
  ],
  "authors": [
    {
      "name": "Tarek Hesham",
      "email": "tarekelfarmawy@outlook.com",
      "homepage": "https://tarekelfarmawy.vercel.app",
      "role": "Developer"
    }
  ],
  "homepage": "https://github.com/tarekhesham/laravel-api-wrapper-template",
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/http": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "phpunit/phpunit": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "ElFarmawy\\Template\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ElFarmawy\\Template\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "ElFarmawy\\Template\\Providers\\TemplateServiceProvider"
      ],
      "aliases": {
        "API": "ElFarmawy\\Template\\Facades\\API"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "support": {
    "email": "tarekelfarmawy@outlook.com",
    "issues": "https://github.com/tarekhesham/laravel-api-wrapper-template/issues",
    "source": "https://github.com/tarekhesham/laravel-api-wrapper-template"
  }
}
