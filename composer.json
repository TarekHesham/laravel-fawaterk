{
  "name": "elfarmawy/laravel-fawaterk",
  "description": "Production-ready Laravel SDK for the Fawaterak payment gateway",
  "type": "library",
  "license": "MIT",
  "version": "1.0.0",
  "keywords": [
    "elfarmawy",
    "laravel",
    "fawaterak",
    "payment",
    "payment-gateway",
    "sdk",
    "api-wrapper"
  ],
  "authors": [
    {
      "name": "Tarek Hesham",
      "email": "tarekelfarmawy@outlook.com",
      "homepage": "https://tarekelfarmawy.vercel.app",
      "role": "Developer"
    }
  ],
  "homepage": "https://github.com/elfarmawy/laravel-fawaterk",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/http": "^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "pestphp/pest": "^2.0|^3.0",
    "pestphp/pest-plugin-laravel": "^2.0|^3.0",
    "nunomaduro/larastan": "^2.0|^3.0",
    "phpstan/phpstan": "^1.10|^2.0"
  },
  "autoload": {
    "psr-4": {
      "ElFarmawy\\Fawaterk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ElFarmawy\\Fawaterk\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "ElFarmawy\\Fawaterk\\Providers\\FawaterkServiceProvider"
      ],
      "aliases": {
        "Fawaterk": "ElFarmawy\\Fawaterk\\Facades\\Fawaterk"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "test": "vendor/bin/pest",
    "analyse": "vendor/bin/phpstan analyse"
  },
  "support": {
    "email": "tarekelfarmawy@outlook.com",
    "issues": "https://github.com/elfarmawy/laravel-fawaterk/issues",
    "source": "https://github.com/elfarmawy/laravel-fawaterk"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
